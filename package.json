{
  "name": "stellarlock",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite --host",
    "dev:testnet": "cp .env.testnet .env && vite --host",
    "dev:staging": "cp .env.staging .env && vite --host",
    "build": "tsc -b && vite build",
    "build:testnet": "cp .env.testnet .env && tsc -b && vite build",
    "build:staging": "cp .env.staging .env && tsc -b && vite build",
    "build:mainnet": "cp .env.mainnet .env && tsc -b && vite build",
    "preview": "vite preview",
    "storybook": "storybook dev -p 6006",
    "storybook:build": "storybook build",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest --coverage",
    "test:load": "node --loader tsx src/test/load-test-runner.ts",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "pnpm": {
    "overrides": {
      "protobufjs": "^7.5.6",
      "vite": ">=6.4.3",
      "vitest": "^3.2.6"
    }
  },
  "dependencies": {
    "@creit.tech/stellar-wallets-kit": "^1.7.6",
    "@stellar/freighter-api": "^6.0.1",
    "@stellar/stellar-sdk": "^13.1.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "i18next": "^26.3.1",
    "i18next-browser-languagedetector": "^8.2.1",
    "lucide-react": "^1.16.0",
    "qrcode.react": "3.2.0",
    "react": "^19",
    "react-dom": "^19",
    "react-helmet-async": "^3.0.0",
    "react-hot-toast": "^2.6.0",
    "react-i18next": "^17.0.8",
    "react-router-dom": "^7.17.0",
    "tailwind-merge": "^3.3.1",
    "web-vitals": "^4.0.1"
  },
  "devDependencies": {
    "@eslint/js": "^10",
    "@storybook/addon-a11y": "^10.4.6",
    "@storybook/addon-essentials": "^8.0.0",
    "@storybook/addon-interactions": "^8.0.0",
    "@storybook/addon-onboarding": "^10.4.6",
    "@storybook/react": "^10.4.6",
    "@storybook/react-vite": "^10.4.6",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/jest-dom": "^6",
    "@testing-library/react": "^16",
    "@testing-library/user-event": "^14",
    "@types/node": "^26",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@vitejs/plugin-react": "^6.0.2",
    "@vitest/ui": "^4",
    "eslint": "^10",
    "eslint-config-prettier": "^10",
    "eslint-plugin-react-hooks": "^7",
    "eslint-plugin-react-refresh": "^0.5",
    "husky": "^9",
    "jsdom": "^29",
    "lint-staged": "^17",
    "prettier": "^3",
    "storybook": "^10.4.6",
    "tailwindcss": "^4",
    "typescript": "6.0.3",
    "typescript-eslint": "^8",
    "vite": "^8",
    "vitest": "^1",
    "vitest-axe": "^0.1.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,css,html}": [
      "prettier --write"
    ]
  }
}
